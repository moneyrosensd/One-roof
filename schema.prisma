// Real persistent database schema — this is what makes logins survive
// a page refresh, unlike the in-memory prototype.
// Run: npx prisma migrate dev --name init

datasource db {
  provider = "postgresql" // Supabase, Neon, Railway, or any Postgres host
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Your app's own data
  store         Store?

  // Billing — 30-day free trial, then a paid subscription to keep posting
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  subscriptionStatus   String?   // "trialing" | "active" | "past_due" | "canceled"
  trialEndsAt          DateTime?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---- Your app's real tables ----
model Store {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  label       String
  tagline     String?
  bgColor     String?
  profilePic  String?
  coverPhoto  String?
  lat         Float?
  lng         Float?
  statusText  String?
  statusSetAt DateTime?
  items       Item[]
  createdAt   DateTime @default(now())
}

model Item {
  id          String    @id @default(cuid())
  storeId     String
  store       Store     @relation(fields: [storeId], references: [id])
  title       String
  description String?
  price       Float?
  category    String
  images      String[]
  status      String    @default("available") // "available" | "sold"
  soldAt      DateTime?
  createdAt   DateTime  @default(now())
}

model Message {
  id             String   @id @default(cuid())
  conversationId String   // deterministic: sorted(userId_a, userId_b)
  fromUserId     String
  toUserId       String
  itemIds        String[] // supports bundling multiple items into one message
  text           String
  createdAt      DateTime @default(now())

  @@index([conversationId])
}
